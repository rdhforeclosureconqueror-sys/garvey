      "author",
      "operational_approver"
    ],
    "bias_sensitivity_reviewer": [
      "primary_subject_matter_reviewer_where_feasible"
    ]
  },
  "conflict_of_interest_rules": {
    "requires_disclosure": true,
    "requires_recusal": true,
    "conflict_categories": [
      "author_or_co_author",
      "direct_supervisor_or_subordinate_where_independence_is_compromised",
      "financial_interest",
      "organizational_conflict",
      "familial_relationship",
      "classroom_or_instructional_responsibility_for_pilot_participants_where_relevant",
      "prior_content_ownership_or_vendor_interest",
      "undisclosed_participation_in_item_development"
    ],
    "disclosure_required_before_review": true,
    "recusal_required_when_independence_is_compromised": true,
    "undisclosed_conflict_triggers_suspension_or_re_review": true
