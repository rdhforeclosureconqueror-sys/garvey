      "mastery_candidate"
    ],
    "curriculum_review": [
      "progress_monitoring_candidate",
      "diagnostic_candidate",
      "mastery_candidate"
    ],
    "subject_matter_review": [
      "progress_monitoring_candidate",
      "diagnostic_candidate",
      "mastery_candidate"
    ],
    "developmental_review": [
      "progress_monitoring_candidate",
      "diagnostic_candidate",
      "mastery_candidate"
    ],
    "accessibility_review": [
      "progress_monitoring_candidate",
      "diagnostic_candidate",
      "mastery_candidate"
    ],
    "bias_sensitivity_review": [
      "progress_monitoring_candidate",
      "diagnostic_candidate",
      "mastery_candidate"
    ],
    "audio_review": [
      "progress_monitoring_candidate",
      "diagnostic_candidate",
      "mastery_candidate"
    ],
    "visual_review": [
      "progress_monitoring_candidate",
      "diagnostic_candidate",
      "mastery_candidate"
    ],
    "approved_for_field_test": [
      "field_test"
    ],
    "field_test": [
      "field_test"
    ],
    "statistical_review": [
      "field_test"
    ],
    "reviewed_candidate": [
      "reviewed_candidate"
    ],
    "validated_operational": [
      "validated_operational"
    ],
    "suspended": [
      "suspended"
    ],
    "retired": [
      "retired"
    ]
  },
  "distinctions": {
    "workflow_state": "Review and lifecycle location of a specific item version.",
    "reviewed_candidate_not_operational": "reviewed_candidate is not equivalent to validated_operational and cannot be used for operational mastery decisions.",
    "field_test_zero_weight": "field_test items have zero decision weight for mastery, readiness, recommendations, placement, and parent-facing decisions.",
    "no_automatic_operation": "No item becomes validated_operational automatically after field test or statistical review. Explicit operational approval is required.",
    "operational_mastery_requirement": "Operational mastery use requires item_status validated_operational.",
    "item_status_definition": "Canonical eligibility label consumed by assessment blueprints and indexes."
  },
  "reviewer_roles": {
    "author": "Creates or revises the item; cannot be sole approver for any required review.",
    "automated_validator": "Runs machine checks and records rule outcomes.",
    "curriculum_reviewer": "Confirms package, grade, domain, construct, and blueprint alignment.",
    "subject_matter_reviewer": "Confirms correctness, construct representation, distractor misconceptions, and no trick wording.",
    "developmental_reviewer": "Confirms age-appropriateness and reading/load expectations.",
    "accessibility_reviewer": "Confirms accommodation and modality equivalence.",
    "bias_sensitivity_reviewer": "Reviews fairness, sensitivity, and unrelated cultural knowledge risks.",
    "audio_reviewer": "Reviews spoken prompt, pronunciation, emphasis, and audio non-disclosure.",
    "visual_reviewer": "Reviews visuals, contrast, target regions, and visual non-disclosure.",
    "psychometric_reviewer": "Reviews field-test statistics, reliability indicators, and differential item functioning.",
    "operational_approver": "Approves validated_operational use after required review evidence is complete.",
    "governance_admin": "Executes emergency suspension, rollback, and retirement records."
  },
  "separation_of_duties": {
    "author_cannot_final_approve": true,
    "statistical_reviewer_distinct_from_author": true,
    "operational_approver_distinct_from_author": true,
    "accessibility_reviewer_required_when_accessibility_behavior_changes": true,
    "emergency_removal_requires_post_hoc_independent_review": true
  },
  "approval_quorum": {
    "approved_for_field_test": [
      "curriculum_reviewer",
      "subject_matter_reviewer",
      "developmental_reviewer",
      "accessibility_reviewer",
      "bias_sensitivity_reviewer"
    ],
    "validated_operational": [
      "psychometric_reviewer",
      "curriculum_reviewer",
      "subject_matter_reviewer",
      "operational_approver"
    ],
    "suspension_release": [
      "governance_admin",
      "role_relevant_reviewer",
      "operational_approver"
    ]
  },
  "required_evidence_by_transition": {
    "draft_to_automated_validation": [
      "complete item metadata",
      "protected/public classification",
      "author change entry"
    ],
    "automated_validation_to_curriculum_review": [
      "no validation errors",
      "warnings triaged"
    ],
    "curriculum_review_to_subject_matter_review": [
      "package/domain/construct alignment approval"
    ],
    "subject_matter_review_to_developmental_review": [
      "correctness approval",
      "distractor misconception approval",
      "no trick wording approval"
    ],
    "developmental_review_to_accessibility_review": [
      "age-appropriate language approval",
      "reading load approval"
    ],
    "accessibility_review_to_bias_sensitivity_review": [
      "modality equivalence approval",
      "accommodation behavior approval"
    ],
    "bias_sensitivity_review_to_audio_review": [
      "fairness/sensitivity approval",
      "unrelated cultural knowledge check"
    ],
    "audio_review_to_visual_review": [
      "audio non-disclosure approval or not-applicable rationale"
    ],
    "visual_review_to_approved_for_field_test": [
      "visual non-disclosure approval or not-applicable rationale",
      "field-test design assignment"
    ],
    "approved_for_field_test_to_field_test": [
      "field-test isolation flag",
      "zero decision weight confirmation"
    ],
    "field_test_to_statistical_review": [
      "sufficient field-test sample or needs-more-data decision",
      "administration policy versions captured"
    ],
    "statistical_review_to_reviewed_candidate": [
      "item statistics review",
      "fairness and DIF review",
      "psychometric recommendation"
    ],
    "reviewed_candidate_to_validated_operational": [
      "operational approval",
      "standard-setting dependency satisfied",
      "blueprint eligibility confirmed"
    ],
    "any_state_to_suspended": [
      "suspension trigger record",
      "affected administrations assessment",
      "emergency removal decision if applicable"
    ],
    "suspended_to_prior_review_state": [
      "root cause resolution",
      "required re-review evidence",
      "rollback or reactivation decision"
    ],
    "any_state_to_retired": [
      "retirement reason",
      "replacement or coverage impact assessment",
      "historical retention confirmation"
    ]
  },
