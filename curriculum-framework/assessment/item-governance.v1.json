      "validated_operational"
    ],
    "suspended": [
      "suspended"
    ],
    "retired": [
      "retired"
    ]
  },
  "distinctions": {
    "workflow_state": "Review and lifecycle location of a specific item version; not exposed in public candidate indexes.",
    "reviewed_candidate_not_operational": "reviewed_candidate is not equivalent to validated_operational and cannot be used for operational mastery, cumulative mixed, or next-grade readiness scored evidence.",
    "field_test_zero_weight": "field_test items have zero decision weight for mastery, readiness, recommendations, placement, and parent-facing decisions and are not operational.",
    "no_automatic_operation": "No item becomes validated_operational automatically after field test, elapsed time, data collection, or statistical review. Explicit operational approval is required.",
    "operational_mastery_requirement": "Only item_status validated_operational with active_status active may be used as scored evidence for mastery, cumulative mixed, and next-grade readiness.",
    "item_status_definition": "Canonical eligibility label consumed by assessment blueprints and indexes.",
    "suspended_not_selectable": "Suspended items are not selectable for operational delivery.",
    "retired_not_selectable": "Retired items are not selectable for any new delivery.",
    "operational_selection_checks": "Operational selection must check both item_status and active_status."
  },
  "reviewer_roles": {
    "author": "Creates or revises the item; cannot be sole approver for any required review.",
    "automated_validator": "Runs machine checks and records rule outcomes.",
    "curriculum_reviewer": "Confirms package, grade, domain, construct, and blueprint alignment.",
    "subject_matter_reviewer": "Confirms correctness, construct representation, distractor misconceptions, and no trick wording.",
    "developmental_reviewer": "Confirms age-appropriateness and reading/load expectations.",
    "accessibility_reviewer": "Confirms accommodation and modality equivalence.",
    "bias_sensitivity_reviewer": "Reviews fairness, sensitivity, and unrelated cultural knowledge risks.",
    "audio_reviewer": "Reviews spoken prompt, pronunciation, emphasis, and audio non-disclosure.",
    "visual_reviewer": "Reviews visuals, contrast, target regions, and visual non-disclosure.",
    "psychometric_reviewer": "Reviews field-test statistics, reliability indicators, and differential item functioning.",
    "operational_approver": "Approves validated_operational use after required review evidence is complete.",
    "governance_admin": "Executes emergency suspension, rollback, and retirement records."
  },
  "separation_of_duties": {
    "author_cannot_final_approve": true,
    "statistical_reviewer_distinct_from_author": true,
    "operational_approver_distinct_from_author": true,
    "accessibility_reviewer_required_when_accessibility_behavior_changes": true,
    "emergency_removal_requires_post_hoc_independent_review": true,
    "author_cannot_approve_own_item": true,
    "operational_approver_distinct_from_psychometric_reviewer": true,
    "bias_sensitivity_reviewer_independent_from_primary_subject_matter_reviewer_where_feasible": true,
    "one_person_cannot_satisfy_all_required_review_roles": true,
    "approved_for_field_test_requires_multiple_independent_people": true,
    "validated_operational_requires_independent_curriculum_subject_psychometric_and_operational_approval": true
  },
  "approval_quorum": {
    "approved_for_field_test": [
      "curriculum_reviewer",
      "subject_matter_reviewer",
      "developmental_reviewer",
      "accessibility_reviewer",
      "bias_sensitivity_reviewer"
    ],
    "validated_operational": [
      "psychometric_reviewer",
      "curriculum_reviewer",
      "subject_matter_reviewer",
      "operational_approver"
    ],
    "suspension_release": [
      "governance_admin",
      "role_relevant_reviewer",
      "operational_approver"
    ]
  },
