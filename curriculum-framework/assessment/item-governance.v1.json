  "versioning_rules": {
    "immutable_administration_snapshot": "Historical administrations retain the exact item version and governance/policy version used at administration time.",
    "material_changes": [
      "evidence statement change",
      "visible prompt meaning change",
      "spoken prompt meaning change",
      "item-status eligibility change",
      "assessment-role eligibility change",
      "scoring key change",
      "acceptable answers change",
      "rubric change",
      "partial-credit logic change",
      "construct change",
      "stimulus meaning change",
      "distractor meaning change",
      "misconception mapping change",
      "accessibility behavior change",
      "audio behavior change",
      "visual behavior change",
      "response geometry change",
      "provenance or licensing rights change"
    ],
    "non_material_changes": [
      "typo correction that does not change meaning",
      "metadata formatting correction",
      "non-scoring provenance clarification",
      "accessibility metadata clarification that does not change behavior"
    ],
    "new_version_required_when": [
      "change could alter construct interpretation",
      "change could alter scoring",
      "change could alter accessibility",
      "change could alter response behavior",
      "change could alter item statistics",
      "change could alter fairness",
      "change could alter operational eligibility",
      "operational item returns to authoring for content revision",
      "field-test data cannot be interpreted under old content",
      "legal/license provenance changes available delivery rights"
    ],
    "controlled_review_required_for": [
      "evidence_statement",
      "visible_prompt meaning",
      "spoken_prompt meaning",
      "item-status eligibility",
      "assessment-role eligibility",
      "scoring key",
      "acceptable answers",
      "rubric",
      "partial-credit logic",
      "construct",
      "stimulus meaning",
      "distractor meaning",
      "misconception mapping",
      "accessibility behavior",
      "audio behavior",
      "visual behavior",
      "response geometry",
      "provenance or licensing rights"
    ],
    "non_material_change_review": "May retain version only with reviewer sign-off and audit entry explaining why administration evidence remains comparable.",
    "material_change_definition": "A material change is any change that could alter construct interpretation, scoring, accessibility, response behavior, item statistics, fairness, or operational eligibility.",
    "non_material_editorial_change_definition": "A non-material editorial change corrects spelling, punctuation, formatting, or non-substantive metadata without altering meaning, scoring, accessibility, response behavior, statistics, fairness, or operational eligibility."
  },
  "field_test_isolation": {
    "zero_decision_weight": true,
    "excluded_decisions": [
      "mastery",
      "readiness",
      "recommendations",
      "placement",
      "parent_facing_decisions"
    ],
    "eligible_for_item_statistics": true,
    "must_not_appear_as_scored_evidence": true,
    "candidate_index_must_mark_field_test_or_withhold_status_as_policy_requires": true,
    "field_test_is_not_operational": true,
    "reviewed_candidate_is_not_operational": true
  },
  "statistical_approval_requirements": {
    "requires_field_test_data": true,
    "requires_item_statistics_review": true,
    "requires_fairness_and_dif_review": true,
    "requires_standard_setting_before_operational_mastery_use": true,
    "no_automatic_promotion": true,
    "minimum_outputs": [
      "sample description",
      "difficulty estimate",
      "discrimination or fit evidence",
      "omitted/not-reached analysis",
      "DIF/fairness screen",
      "psychometric recommendation"
    ]
  },
  "suspension_triggers": [
    "scoring-key defect",
    "rubric ambiguity",
    "content inaccuracy",
    "construct misalignment",
    "accessibility failure",
    "bias/sensitivity concern",
    "answer exposure",
    "statistical drift",
    "security compromise",
    "duplicate operational item conflict",
    "legal or licensing issue"
  ],
  "retirement_rules": [
    "Retire when content is obsolete, invalid, overexposed, unrecoverably biased, replaced by superior coverage, or no longer aligned to curriculum/package standards.",
    "Retired items are not returned to operational use without creating a new version and restarting governance review.",
    "Retirement records preserve historical administrations and prior scoring policy."
  ],
  "emergency_removal": {
    "allowed_from": [
      "field_test",
      "reviewed_candidate",
      "validated_operational"
    ],
    "target_state": "suspended",
    "requires_post_hoc_review_within_policy_window": true,
    "must_record_affected_forms": true
  },
  "rollback": {
    "description": "Rollback restores the last approved item/policy version for future administrations only; past administrations retain original snapshots.",
    "requires_audit_entry": true,
    "requires_operational_approver_for_operational_items": true
  },
  "validation_rules": [
    {
      "rule_id": "GOV-VAL-001",
      "severity": "error",
      "description": "workflow_state must be defined in workflow_state_vocabulary."
    },
    {
      "rule_id": "GOV-VAL-002",
      "severity": "error",
      "description": "item_status must be defined in canonical_item_status_vocabulary."
    },
    {
      "rule_id": "GOV-VAL-003",
      "severity": "error",
      "description": "Every transition target must be a defined workflow state."
    },
    {
      "rule_id": "GOV-VAL-004",
      "severity": "error",
      "description": "Non-terminal workflow states must have at least one outgoing transition."
    },
    {
      "rule_id": "GOV-VAL-005",
      "severity": "error",
      "description": "No path may move field_test to validated_operational without statistical_review and reviewed_candidate operational approval."
    },
    {
      "rule_id": "GOV-VAL-006",
      "severity": "error",
