{
  "standard_id": "assessment-item-governance-v1",
  "version": "1.0.0",
  "status": "provisional_governance_standard",
  "purpose": "Machine-readable workflow, validation, audit, versioning, and operational-readiness governance standard for future assessment items. This is not a runtime API and does not itself establish psychometric validity.",
  "canonical_item_status_vocabulary": [
    "instruction_only",
    "practice",
    "progress_monitoring_candidate",
    "diagnostic_candidate",
    "mastery_candidate",
    "field_test",
    "reviewed_candidate",
    "validated_operational",
    "suspended",
    "retired"
  ],
  "workflow_state_vocabulary": [
    "draft",
    "automated_validation",
    "curriculum_review",
    "subject_matter_review",
    "developmental_review",
    "accessibility_review",
    "bias_sensitivity_review",
    "audio_review",
    "visual_review",
    "approved_for_field_test",
    "field_test",
    "statistical_review",
    "reviewed_candidate",
    "validated_operational",
    "suspended",
    "retired"
  ],
  "validation_severity_levels": [
    "error",
    "warning",
    "review_required"
  ],
  "terminal_workflow_states": [
    "retired"
  ],
  "workflow_state_to_item_status_alignment": {
