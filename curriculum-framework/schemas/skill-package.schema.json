{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillPackage",
  "type": "object",
  "required": ["skill_id", "grade", "subject", "domain", "skill", "mastery_threshold", "lesson", "worked_examples", "hint_ladder", "guided_practice", "checkpoint", "adaptive_question_bank", "misconception_bank", "review_bank", "game_theme"],
  "properties": {
    "skill_id": { "type": "string" },
    "grade": { "type": "integer" },
    "subject": { "type": "string" },
    "domain": { "type": "string" },
    "skill": { "type": "string" },
    "mastery_threshold": { "type": "number" },
    "difficulty_range": { "type": "array", "items": { "type": "number" } },
    "lesson": { "type": "object" },
    "worked_examples": { "type": "array", "items": { "type": "object" } },
    "hint_ladder": { "type": "array", "items": { "type": "string" } },
    "guided_practice": { "$ref": "#/$defs/questions" },
    "checkpoint": { "$ref": "#/$defs/questions" },
    "adaptive_question_bank": { "$ref": "#/$defs/questions" },
    "level_banks_status": { "enum": ["not_applicable", "planned"] },
    "level_banks": { "type": "array", "minItems": 4, "items": { "$ref": "#/$defs/level_bank" } },
    "misconception_bank": { "type": "object" },
    "review_bank": { "type": "array", "items": { "type": "object" } },
    "game_theme": { "type": "object" },
    "next_skill_id": { "type": "string" },
    "remediation_skill_id": { "type": "string" }
  },
  "oneOf": [
    { "required": ["level_banks"] },
    { "properties": { "level_banks_status": { "const": "not_applicable" } }, "required": ["level_banks_status"] },
    { "properties": { "level_banks_status": { "const": "planned" } }, "required": ["level_banks_status"] }
  ],
  "$defs": {
    "questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/question" }
    },
    "question": {
      "type": "object",
      "required": ["question_type", "prompt", "misconception_tag"],
      "anyOf": [
        { "required": ["id"] },
        { "required": ["question_id"] }
      ],
      "properties": {
        "id": { "type": "string" },
        "question_id": { "type": "string" },
        "question_type": { "enum": ["multiple_choice", "short_response", "visual_objects", "number_sequence", "number_line", "comparison", "comparison_cards", "base_ten_blocks", "place_value_chart", "addition_model", "subtraction_model", "number_bond", "shape_identification", "measurement_comparison", "pattern_completion", "sorting_visual"] },
        "support_type": { "type": "string" },
        "visual_model": { "type": "string" },
        "prompt": { "type": "string" },
        "choices": { "type": "array" },
        "options": { "type": "array" },
        "acceptable_answers": { "type": "array" },
        "answer": {},
        "correct_answer": {},
        "hints": { "type": "array" },
        "hint_ladder": { "type": "array" },
        "misconception_tag": { "type": "string" },
        "explanation": { "type": "string" },
        "feedback": { "type": "string" }
      }
    },
    "level_bank": {
      "type": "object",
      "required": ["level_id", "label", "focus", "difficulty", "question_count_required", "mastery_threshold", "questions"],
      "properties": {
        "level_id": { "type": "string" },
        "label": { "type": "string" },
        "focus": { "type": "string" },
        "difficulty": { "type": "number" },
        "question_count_required": { "type": "integer", "minimum": 10, "maximum": 12 },
        "mastery_threshold": { "type": "number" },
        "questions": { "type": "array", "minItems": 10, "maxItems": 12, "items": { "$ref": "#/$defs/question" } }
      }
    }
  }
}
