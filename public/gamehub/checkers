    .gamehub-practice-mode { font-size: 0.85rem; font-weight: 600; opacity: 0.92; }
    .gamehub-back-link { font-size: 0.85rem; font-weight: 700; text-decoration: none; border-bottom: 1px solid currentColor; }
  </style>

</head>
<body>
    <h1>Checkers Game</h1>
    
    <div class="game-info">
        <div class="status" id="status">Red's Turn</div>
        <div class="controls">
            <button id="resetBtn">New Game</button>
            <button id="hintBtn">Show Hints</button>
        </div>
    </div>
    
    <div class="board" id="board"></div>
    
    <div class="instructions">
        <h3>How to Play:</h3>
        <ul>
            <li>Red moves first</li>
            <li>Regular pieces move diagonally forward</li>
            <li>Kings can move diagonally in any direction</li>
            <li>Capture opponent pieces by jumping over them</li>
            <li>Multiple jumps in one turn are allowed</li>
            <li>Win by capturing all opponent pieces</li>
        </ul>
    </div>

    <script>
        // Game state
        let currentPlayer = 'red';
        let selectedPiece = null;
        let validMoves = [];
        let boardState = [];
        let gameActive = true;
        let showHints = false;

        // Initialize the board
        function initializeBoard() {
            boardState = Array(8).fill().map(() => Array(8).fill(null));
            
            // Set up initial pieces
            for (let row = 0; row < 8; row++) {
                for (let col = 0; col < 8; col++) {
                    // Pieces only on dark squares
                    if ((row + col) % 2 === 1) {
                        if (row < 3) {
                            boardState[row][col] = { player: 'black', king: false };
                        } else if (row > 4) {
                            boardState[row][col] = { player: 'red', king: false };
                        }
                    }
                }
            }
            
            renderBoard();
            updateStatus();
        }

        // Render the board
        function renderBoard() {
            const board = document.getElementById('board');
            board.innerHTML = '';
            
            for (let row = 0; row < 8; row++) {
                for (let col = 0; col < 8; col++) {
                    const cell = document.createElement('div');
                    cell.className = `cell ${(row + col) % 2 === 0 ? 'light' : 'dark'}`;
                    cell.dataset.row = row;
                    cell.dataset.col = col;
                    
                    // Add click event to cells
                    cell.addEventListener('click', () => handleCellClick(row, col));
                    
                    // Add piece if exists
                    const piece = boardState[row][col];
                    if (piece) {
                        const pieceEl = document.createElement('div');
                        pieceEl.className = `piece ${piece.player} ${piece.king ? 'king' : ''}`;
                        cell.appendChild(pieceEl);
                        
                        // Highlight selected piece
                        if (selectedPiece && selectedPiece.row === row && selectedPiece.col === col) {
                            pieceEl.classList.add('selected');
                        }
                    }
                    
                    // Show valid moves
                    if (showHints && isValidMove(row, col)) {
                        cell.classList.add('valid-move');
                    }
                    
                    board.appendChild(cell);
                }
            }
        }

        // Handle cell click
        function handleCellClick(row, col) {
            if (!gameActive) return;
            
            const piece = boardState[row][col];
            
            // If clicking on a piece of the current player
            if (piece && piece.player === currentPlayer) {
                selectedPiece = { row, col };
                validMoves = calculateValidMoves(row, col);
                renderBoard();
                return;
            }
            
            // If a piece is selected and clicking on a valid move
            if (selectedPiece && isValidMove(row, col)) {
                movePiece(selectedPiece.row, selectedPiece.col, row, col);
                selectedPiece = null;
                validMoves = [];
                
                // Check for additional jumps
                const additionalJumps = calculateValidMoves(row, col).filter(move => move.isJump);
                if (additionalJumps.length > 0) {
                    selectedPiece = { row, col };
                    validMoves = additionalJumps;
                    renderBoard();
                    return;
                }
                
                // Switch player if no additional jumps
                currentPlayer = currentPlayer === 'red' ? 'black' : 'red';
                renderBoard();
                updateStatus();
                
                // Check for win condition
                if (checkWinCondition()) {
                    gameActive = false;
                    document.getElementById('status').textContent = `${currentPlayer === 'red' ? 'Black' : 'Red'} Wins!`;
                }
            }
        }

        // Check if a move is valid
        function isValidMove(toRow, toCol) {
            return validMoves.some(move => move.row === toRow && move.col === toCol);
        }

        // Calculate valid moves for a piece
        function calculateValidMoves(row, col) {
            const piece = boardState[row][col];
            if (!piece) return [];
            
            const moves = [];
            const directions = [];
            
            // Regular pieces move forward, kings move in both directions
            if (piece.player === 'red' || piece.king) {
                directions.push({ row: -1, col: -1 }, { row: -1, col: 1 });
            }
            if (piece.player === 'black' || piece.king) {
                directions.push({ row: 1, col: -1 }, { row: 1, col: 1 });
            }
            
            // Check for regular moves and jumps
            for (const dir of directions) {
                const newRow = row + dir.row;
                const newCol = col + dir.col;
                
                // Check if within board
                if (newRow >= 0 && newRow < 8 && newCol >= 0 && newCol < 8) {
                    // Regular move to empty square
                    if (!boardState[newRow][newCol]) {
                        moves.push({ row: newRow, col: newCol, isJump: false });
                    }
                    // Jump over opponent piece
                    else if (boardState[newRow][newCol].player !== piece.player) {
                        const jumpRow = newRow + dir.row;
                        const jumpCol = newCol + dir.col;
                        
                        // Check if jump destination is valid and empty
                        if (jumpRow >= 0 && jumpRow < 8 && jumpCol >= 0 && jumpCol < 8 && 
                            !boardState[jumpRow][jumpCol]) {
                            moves.push({ row: jumpRow, col: jumpCol, isJump: true, captured: { row: newRow, col: newCol } });
                        }
                    }
                }
            }
            
            return moves;
        }

        // Move a piece
        function movePiece(fromRow, fromCol, toRow, toCol) {
            const piece = boardState[fromRow][fromCol];
            boardState[fromRow][fromCol] = null;
            boardState[toRow][toCol] = piece;
            
            // Check if piece becomes a king
            if ((piece.player === 'red' && toRow === 0) || (piece.player === 'black' && toRow === 7)) {
                piece.king = true;
            }
            
            // Remove captured piece if it was a jump
            const move = validMoves.find(m => m.row === toRow && m.col === toCol);
            if (move && move.isJump) {
                boardState[move.captured.row][move.captured.col] = null;
            }
        }

        // Check win condition
        function checkWinCondition() {
            let redPieces = 0;
            let blackPieces = 0;
            
            for (let row = 0; row < 8; row++) {
                for (let col = 0; col < 8; col++) {
                    const piece = boardState[row][col];
                    if (piece) {
                        if (piece.player === 'red') redPieces++;
                        else blackPieces++;
                    }
                }
            }
            
            return redPieces === 0 || blackPieces === 0;
        }

        // Update game status
        function updateStatus() {
            const status = document.getElementById('status');
            status.textContent = `${currentPlayer === 'red' ? 'Red' : 'Black'}'s Turn`;
            status.style.backgroundColor = currentPlayer === 'red' ? 'rgba(255, 0, 0, 0.3)' : 'rgba(0, 0, 0, 0.3)';
        }

        // Reset the game
        function resetGame() {
            currentPlayer = 'red';
            selectedPiece = null;
            validMoves = [];
            gameActive = true;
            showHints = false;
            initializeBoard();
        }

        // Toggle hints
        function toggleHints() {
            showHints = !showHints;
            renderBoard();
            document.getElementById('hintBtn').textContent = showHints ? 'Hide Hints' : 'Show Hints';
        }

        // Initialize the game
        document.getElementById('resetBtn').addEventListener('click', resetGame);
        document.getElementById('hintBtn').addEventListener('click', toggleHints);
        
        // Start the game
        initializeBoard();
    </script>

