    .gamehub-shared-identity { display:flex; align-items:center; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; margin: 0 0 0.75rem; padding: 0.55rem 0.75rem; border-radius: 10px; border: 1px solid rgba(148,163,184,0.45); background: rgba(15,23,42,0.16); }
