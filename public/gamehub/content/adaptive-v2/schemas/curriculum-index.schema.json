{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adaptive-v2/curriculum-index.schema.json",
  "title": "Adaptive V2 Curriculum Index",
  "type": "object",
  "required": ["schema_version", "generated_from", "phase_gap_policy", "entries"],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "generated_from": { "type": "string" },
    "phase_gap_policy": {
      "type": "object",
      "required": ["missing_phases_allowed", "notes"],
      "properties": {
        "missing_phases_allowed": {
          "type": "array",
          "items": { "type": "string" },
          "contains": { "const": "Phase 10" }
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "phase_id",
          "phase_folder",
          "source_file",
          "inferred_grade",
          "inferred_subject",
          "inferred_content_type",
          "conversion_status",
          "needs_review",
          "notes"
        ],
        "properties": {
          "phase_id": { "type": "string" },
          "phase_folder": { "type": "string" },
          "source_file": { "type": "string" },
          "inferred_grade": { "type": "string" },
          "inferred_subject": { "type": "string" },
          "inferred_content_type": { "type": "string" },
          "conversion_status": { "type": "string", "enum": ["indexed_only", "planned", "converted"] },
          "needs_review": { "type": "boolean" },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
