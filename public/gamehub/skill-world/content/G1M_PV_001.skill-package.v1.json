  "lesson": {
    "story_mission": "Pack fireflies into lantern crates so every 10 ones becomes 1 ten.",
    "mini_lesson": "A ten is a bundle of 10 ones. Two-digit numbers tell how many tens and how many ones are in the number. For 47, the 4 means 4 tens and the 7 means 7 ones."
  },
  "worked_examples": [
    {
      "text": "10 ones = 1 ten, so 10 loose cubes can be bundled into one ten-rod."
    },
    {
      "text": "36 has 3 tens and 6 ones because 30 + 6 = 36."
    },
    {
      "text": "8 tens and 2 ones make 82 because 80 + 2 = 82."
    }
  ],
  "hint_ladder": [
    "Circle each full group of 10 ones first.",
    "Read the tens digit to count tens, then read the ones digit to count ones.",
    "Check by adding tens value plus ones value."
  ],
