const QUESTION_BANK_PATH="/gamehub/content/question-bank.sample.json";
function parseGrade(value, fallback){ const grade = Number(value); return Number.isFinite(grade) ? grade : fallback; }
function parseDifficulty(value, fallback){ const difficulty = Number(value); return Number.isFinite(difficulty) ? difficulty : fallback; }
async function bootstrapQuestionBank(){
  const shared = globalThis.GamehubSharedContent;
  if (!shared || typeof shared.loadQuestionBank !== "function" || typeof shared.fromQuestionBankToAdaptiveItems !== "function") {
    state.questionBankSource = "fallback";
    return;
  }
  const payload = await shared.loadQuestionBank(QUESTION_BANK_PATH, null);
  if (!payload) { state.questionBankSource = "fallback"; return; }
  const adapted = shared.fromQuestionBankToAdaptiveItems(payload).map((item)=>({
    ...item,
    grade: parseGrade(item.grade, 3),
    difficulty: parseDifficulty(item.difficulty, 2),
    question_type: "multiple_choice",
    correct_explanation: item.correct_explanation || "",
    wrong_feedback: item.wrong_feedback || "",
    celebration_text: item.celebration_text || "",
    passage: item.passage || ""
  }));
  if (adapted.length) {
    QUESTION_BANK.splice(0, QUESTION_BANK.length, ...adapted);
    const activeRange = QUESTION_BANK.filter((item)=>item.grade>=1&&item.grade<=6);
    if (activeRange.length) {
      QUESTION_BANK.splice(0, QUESTION_BANK.length, ...activeRange);
      state.questionBankSource = "shared-question-bank (active grades 1-6; legacy 6-8 archived fallback)";
    } else {
      state.questionBankSource = "shared-question-bank";
    }
  }
}
