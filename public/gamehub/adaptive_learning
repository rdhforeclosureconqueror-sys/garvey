  }
  return null;
}
async function loadGrade1V2Catalog(){
  const manifest=await loadGrade1CatalogManifest();
  if(!manifest||!manifest.subjects) throw new Error('grade1_manifest_missing');
  const catalog={grade:1,subjects:{}};
  for(const [key,sub] of Object.entries(manifest.subjects||{})){
    const skills=[];
    for(const skill of (sub.skills||[])){
      if(!(skill.lesson_package&&skill.checkpoint)) continue;
      const [lessonRes,checkpointRes]=await Promise.all([fetch(skill.lesson_package),fetch(skill.checkpoint)]);
      if(!lessonRes.ok||!checkpointRes.ok) continue;
      const [lesson,checkpoint]=await Promise.all([lessonRes.json(),checkpointRes.json()]);
      skills.push({key:String(skill.key||'').toLowerCase(),lesson,checkpoint});
    }
    catalog.subjects[key]={label:sub.label||key,skills:skills.sort((a,b)=>a.key.localeCompare(b.key))};
  }
  return catalog;
}
