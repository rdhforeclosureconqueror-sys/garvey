function startSession(opts){sessionEnded=false;state.sessionStartedAt=Date.now();state.session={studentName:opts.studentName||getRuntimeContext().child_display_name||DEFAULT_LEARNER_NAME,subject:opts.subject,startingGrade:Number(opts.startingGrade),questionCount:Number(opts.questionCount),mode:opts.mode,goal:opts.goal,currentGradeTarget:Number(opts.startingGrade),currentDifficulty:(opts.startingDifficultyOverride??(opts.goal==="support"?1:opts.goal==="stretch"?3:Math.min(3,Math.max(1,Number(opts.startingGrade)-5)))),consecutiveCorrect:0,consecutiveWrong:0,highestGradeSeen:Number(opts.startingGrade),lowestGradeSeen:Number(opts.startingGrade),questionNumber:0,startedAt:new Date().toISOString()};state.pool=filterBank(opts.subject);state.currentIndex=0;state.results=[];ensureAdapterSession();emitAdapterEvent("activity_selected",{game_key:GAME_KEY,activity_key:ACTIVITY_KEY,mode:opts.mode||"local_pilot",subject:opts.subject==="Mixed"?"mixed":opts.subject.toLowerCase()});show(byId("quizScreen"));hide(byId("startScreen"));hide(byId("historyScreen"));hide(byId("resultsScreen"));nextQuestion()}
