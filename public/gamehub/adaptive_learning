function updateAdaptiveState(correct,q){const s=state.session;const previousGradeTarget=s.currentGradeTarget;const previousDifficulty=s.currentDifficulty;if(correct){s.consecutiveCorrect+=1;s.consecutiveWrong=0;if(q.grade>s.highestGradeSeen) s.highestGradeSeen=q.grade;if(s.consecutiveCorrect>=2){s.currentGradeTarget=Math.min(6,s.currentGradeTarget+1);s.currentDifficulty=Math.min(3,s.currentDifficulty+1);s.consecutiveCorrect=0}}else{s.consecutiveWrong+=1;s.consecutiveCorrect=0;if(q.grade<s.lowestGradeSeen) s.lowestGradeSeen=q.grade;if(s.consecutiveWrong>=2){s.currentGradeTarget=Math.max(1,s.currentGradeTarget-1);s.currentDifficulty=Math.max(1,s.currentDifficulty-1);s.consecutiveWrong=0}}if(previousDifficulty!==s.currentDifficulty||previousGradeTarget!==s.currentGradeTarget){emitAdapterEvent("level_changed",{game_key:GAME_KEY,activity_key:ACTIVITY_KEY,mode:s.mode||"local_pilot",difficulty_band:getDifficultyBand(),grade_band:getGradeBand()});emitAdapterEvent("challenge_selected",{game_key:GAME_KEY,activity_key:ACTIVITY_KEY,mode:s.mode||"local_pilot",difficulty_band:getDifficultyBand(),grade_band:getGradeBand()})}}
function summarizeResults(results){const total=results.length;const correct=results.filter(r=>r.is_correct).length;const accuracy=total?Math.round((correct/total)*100):0;const byDomain={},byGrade={},bySkill={};results.forEach(r=>{if(!byDomain[r.domain]) byDomain[r.domain]={correct:0,total:0,subject:r.subject};if(!byGrade[r.grade]) byGrade[r.grade]={correct:0,total:0};if(!bySkill[r.skill]) bySkill[r.skill]={correct:0,total:0,prerequisite:r.prerequisite_skill,domain:r.domain,grade:r.grade,subject:r.subject};byDomain[r.domain].total+=1;byGrade[r.grade].total+=1;bySkill[r.skill].total+=1;if(r.is_correct){byDomain[r.domain].correct+=1;byGrade[r.grade].correct+=1;bySkill[r.skill].correct+=1}});const strengths=[],developing=[],gaps=[];Object.entries(bySkill).forEach(([skill,data])=>{const pct=Math.round((data.correct/data.total)*100);const item={skill,...data,pct};if(pct>=100) strengths.push(item);else if(pct>=50) developing.push(item);else gaps.push(item)});strengths.sort((a,b)=>b.grade-a.grade||a.skill.localeCompare(b.skill));developing.sort((a,b)=>a.pct-b.pct||a.grade-b.grade);gaps.sort((a,b)=>a.pct-b.pct||a.grade-b.grade);const highestCorrectGrade=results.filter(r=>r.is_correct).reduce((m,r)=>Math.max(m,r.grade),state.session.startingGrade);const highestSeen=Math.max(state.session.startingGrade,state.session.highestGradeSeen);const readinessLabel=getReadinessLabel(accuracy,highestCorrectGrade,highestSeen);const recommendedPath=buildLearningPath(gaps,developing);return {total,correct,accuracy,byDomain,byGrade,bySkill,strengths,developing,gaps,highestCorrectGrade,highestSeen,readinessLabel,recommendedPath}}
function getReadinessLabel(accuracy,highestCorrectGrade,highestSeen){if(accuracy>=85&&highestCorrectGrade>=highestSeen) return "Above-level developing"; if(accuracy>=75) return "On-level secure"; if(accuracy>=55) return "On-level developing"; if(accuracy>=40) return "Foundational support + developing stretch"; return "Foundational support needed"}
function buildLearningPath(gaps,developing){const seen=new Set();const steps=[];gaps.forEach(g=>{if(g.prerequisite&&!seen.has(g.prerequisite)){steps.push({type:"prerequisite",text:`Strengthen prerequisite: ${g.prerequisite}`,why:`This supports the missed skill "${g.skill}".`});seen.add(g.prerequisite)}if(!seen.has(g.skill)){steps.push({type:"target",text:`Practice target skill: ${g.skill}`,why:`This was a priority gap in ${g.domain}.`});seen.add(g.skill)}});developing.forEach(d=>{if(!seen.has(d.skill)){steps.push({type:"developing",text:`Reinforce developing skill: ${d.skill}`,why:`Performance was partial, so more practice can stabilize it.`});seen.add(d.skill)}});steps.push({type:"retest",text:"Retest with a short 5-question check",why:"Use a mini reassessment after practicing the path above."});return steps.slice(0,8)}
