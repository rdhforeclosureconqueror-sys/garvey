  host.className = 'gamehub-shared-identity';
  const params = new URLSearchParams(window.location.search || '');
  const mode = (params.get('mode_preset') || 'standard').toLowerCase();
  const modeLabel = mode.charAt(0).toUpperCase() + mode.slice(1);
  host.innerHTML = `
    <div class="gamehub-shared-badge">GameHub Practice</div>
    <div class="gamehub-practice-mode" aria-live="polite">Practice mode: ${modeLabel}</div>
    <a class="gamehub-back-link" href="/gamehub/index.html">Back to GameHub</a>
  `;
  const placementTargets = [
    '#menu .card',
    '#startScreen',
    '.start-screen',
    '.menu',
    'main',
    'body'
  ];
  const target = placementTargets
    .map((selector) => body.querySelector(selector))
    .find(Boolean) || body;
  target.insertBefore(host, target.firstChild);
})();
</script>

</body>
</html>
